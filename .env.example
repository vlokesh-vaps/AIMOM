# ---------------------------------------------------------------------------
# Speech-to-Text & Transcription Keys
# ---------------------------------------------------------------------------

# NVIDIA NIM API Key (from https://build.nvidia.com)
NVIDIA_API_KEY=

# Deepgram API Key (from https://console.deepgram.com)
DEEPGRAM_API_KEY=

# ---------------------------------------------------------------------------
# Phase 3: AI Intelligence API Keys & Defaults
# ---------------------------------------------------------------------------

# Groq Cloud API Key (from https://console.groq.com)
GROQ_API_KEY=

# Google Gemini API Key (from https://aistudio.google.com)
GEMINI_API_KEY=

# Local Ollama connection URL
OLLAMA_BASE_URL=http://localhost:11434

# Primary Provider selector (options: nvidia, groq, gemini, ollama)
AI_PROVIDER=nvidia

# Primary Model identifier
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# LLM generation parameters
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=4096
AI_TOP_P=1.0
AI_TIMEOUT=60

# ---------------------------------------------------------------------------
# Phase 4: Corporate Reporting & Branding
# ---------------------------------------------------------------------------

# Corporate name printed on PDF footer and header
COMPANY_NAME=VAPS TECHNOSOFT PVT. LTD.

# Corporate logo path drawn on PDF header cover
COMPANY_LOGO_PATH=C:\Users\Vaps\PycharmProjects\AIMOM\company logo.png

# Primary theme color (HEX code)
COMPANY_THEME_COLOR=#1e3a8a

# Secondary theme accent color (HEX code)
COMPANY_SECONDARY_COLOR=#3b82f6
